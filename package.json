{
  "name": "@altrepo/hash",
  "version": "0.1.0",
  "description": "A lightweight multi-environment utility library for generating hashes and verifying checksums for text, bytes, and files.",
  "exports": {
    ".": "./dist/shared.js",
    "./node": "./dist/node.js",
    "./browser": "./dist/browser.js"
  },
  "typesVersions": {
    "*": {
      "node": [
        "dist/node.d.ts"
      ],
      "browser": [
        "dist/browser.d.ts"
      ],
      "*": [
        "dist/shared.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hash",
    "checksum",
    "sha256",
    "sha512",
    "sha3",
    "blake2",
    "browser",
    "node",
    "webcrypto",
    "altrepo"
  ],
  "homepage": "https://altrepo.net/hash/text-hash-generator.html",
  "repository": {
    "type": "git",
    "url": "https://github.com/alterpoYT/altrepo-hash.git"
  },
  "bugs": {
    "url": "https://github.com/alterpoYT/altrepo-hash/issues"
  },
  "author": "AltRepo <void@altrepo.net>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
